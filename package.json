{
  "name": "express_react_template",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "build": "run-s ensure-manifest webpack:client webpack:server",
    "lint:json": "prettier --check '**/*.json'",
    "lint:ts": "prettier --check --parser typescript --config package.json '**/*.ts*'",
    "lint:tsc": "tsc --noEmit --project .",
    "lint:eslint": "eslint .",
    "lint": "run-s lint:eslint lint:tsc lint:ts lint:json",
    "nodemon": "nodemon --watch build build/server.js",
    "prettier-json": "prettier --config package.json --write '**/*.json'",
    "prettier-ts": "prettier --parser typescript --config package.json --write '**/*.ts*'",
    "format": "run-s prettier-ts prettier-json",
    "start": "node build/server.js",
    "s": "run-p touch watch:build nodemon",
    "test": "jest",
    "ensure-manifest": "node -e \"var f=require('fs');f.existsSync('manifest.json')||f.writeFileSync('manifest.json','{\\\"main.js\\\":\\\"\\\",\\\"main.css\\\":\\\"\\\"}')\"",
    "touch": "mkdir -p build && touch build/server.js && run-s ensure-manifest",
    "watch:build": "webpack --mode development --watch",
    "webpack:client": "webpack --mode production --config-name='client'",
    "webpack:server": "webpack --mode production --config-name='server'"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "express": "^4.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "css-loader": "^7.1.0",
    "cssnano": "^7.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.37.0",
    "jest": "^29.7.0",
    "mini-css-extract-plugin": "^2.9.0",
    "nodemon": "^3.1.0",
    "npm-run-all2": "^7.0.0",
    "postcss": "^8.5.0",
    "postcss-import": "^16.1.0",
    "postcss-loader": "^8.1.0",
    "postcss-preset-env": "^10.1.0",
    "prettier": "^3.4.0",
    "source-map-loader": "^5.0.0",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "webpack": "^5.97.0",
    "webpack-cli": "^6.0.0",
    "webpack-manifest-plugin": "^5.0.0",
    "webpack-node-externals": "^3.0.0"
  },
  "prettier": {
    "singleQuote": true,
    "semi": false
  }
}
